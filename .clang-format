# .clang-format - Clang formatting configuration
# Based on the project's Makefile settings (C99, gcc-compatible)

# Base style: LLVM is a good starting point for C projects
BasedOnStyle: LLVM

# Language-specific settings for C
Language: C

# Indentation: 4 spaces (common C convention)
IndentWidth: 4
TabWidth: 4
UseTab: Never

# Column limit: 80 characters (traditional C convention)
ColumnLimit: 80

# Break before braces for control flow statements (Allman style)
BreakBeforeBraces: Allman

# Keep empty function definitions on one line
AllowShortFunctionsOnASingleLine: Empty

# Don't allow short if/while/for on one line (readability)
AllowShortIfStatementsOnASingleLine: Never
AllowShortWhileStatementsOnASingleLine: False
AllowShortForStatementsOnASingleLine: False

# Indent case labels
IndentCaseLabels: true

# Always break after return type for function definitions
AlwaysBreakAfterReturnType: FunctionDefinitions

# Pointer alignment: right (C convention: int* ptr)
PointerAlignment: Right
ReferenceAlignment: Right

# Align consecutive assignments, declarations, macros, and bitfields
AlignConsecutiveAssignments:
  Enabled: true
  AcrossEmptyLines: true
AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: true
AlignConsecutiveMacros:
  Enabled: true
  AcrossEmptyLines: true
AlignConsecutiveBitFields:
  Enabled: true
  AcrossEmptyLines: true

# Array of structures alignment
AlignArrayOfStructures: Left

# Break after open bracket, but not before close bracket
BreakAfterOpenBracket: true
BreakBeforeCloseBracket: false

# Blank line after access modifier (for C++ compatibility)
EmptyLineBeforeAccessModifier: LogicalFile

# Maximum empty lines to keep (keep code compact)
MaxEmptyLinesToKeep: 1

# Space before assignment operators
SpaceBeforeAssignmentOperators: true

# C-style cast spacing
SpaceAfterCStyleCast: false

# Space before parentheses for control statements
SpaceBeforeParens: ControlStatements

# Break string literals
BreakStringLiterals: true
StringLiteralBreakPolicy: BreakBeforeContinuation

# Insert final newline
InsertFinalNewline: true

# Wrap comments
WrapComments: true
CommentWidth: 80

# Break constructor initializers before colon
BreakConstructorInitializers: BeforeColon

# Bit field colon spacing
SpaceBeforeBitfieldColon: true
SpaceAfterBitfieldColon: true

# Indent width for wrapped lines
ContinuationIndentWidth: 4
